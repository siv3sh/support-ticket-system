# Flask
FLASK_SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development
PORT=5005

# MongoDB (use either MONGODB_URI or the separate variables)
# MONGODB_URI=mongodb://user:pass@host:27017/dbname?authSource=admin
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_AUTH_SOURCE=admin
MONGODB_DATABASE=Infinitytest

# Email (Gmail: use an App Password)
EMAIL_ADDRESS=your-support@gmail.com
EMAIL_PASSWORD=your-app-password
IMAP_SERVER=imap.gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Optional
EMAIL_POLL_INTERVAL=10
AUTO_REPLY_ENABLED=true

# Optional: Gemini for AI reply suggestions
GEMINI_API_KEY=

# Optional: Phase 2 ML model prefix (default: ticket_model)
# TICKET_MODEL_PREFIX=phase_2/ticket_model

# First-time setup: allow any email as admin when DB is empty (dev only if ALLOW_FIRST_TIME_SETUP=1)
# ALLOW_FIRST_TIME_SETUP=1
